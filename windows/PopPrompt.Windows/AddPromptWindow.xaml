<Window x:Class="PopPrompt.Windows.AddPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Prompt"
        Width="460"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Black"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="Black"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            CornerRadius="24"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="New Prompt"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Save a reusable prompt in a clean monochrome workspace."
                               Foreground="#99FFFFFF"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Click="OnCloseClick"
                        Background="#14FFFFFF"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="14,8"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="0,22,0,0">
                <TextBlock Text="TITLE"
                           Foreground="#B8FFFFFF"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <Border Margin="0,10,0,0"
                        CornerRadius="16"
                        Background="#0FFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        Padding="14,12">
                    <TextBox x:Name="TitleTextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             CaretBrush="White"
                             FontSize="14" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,18,0,0">
                <TextBlock Text="CONTENT"
                           Foreground="#B8FFFFFF"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <Border Margin="0,10,0,0"
                        CornerRadius="18"
                        Background="#0FFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1"
                        Padding="10">
                    <TextBox x:Name="ContentTextBox"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             CaretBrush="White"
                             FontSize="14"
                             Height="220" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Cancel"
                        Click="OnCloseClick"
                        Background="#14FFFFFF"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="16,10"
                        Cursor="Hand"
                        Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Save"
                        Click="OnSaveClick"
                        Background="White"
                        Foreground="Black"
                        BorderThickness="0"
                        Padding="20,10"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="999">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
